{
  "name": "@ble-multimeter/web-bluetooth",
  "version": "0.0.1",
  "description": "Web Bluetooth transport + the framework-agnostic MeterSession engine for BLE multimeters.",
  "author": "mannes <info@mbtech.nl>",
  "license": "MIT",
  "keywords": [
    "multimeter",
    "dmm",
    "ble",
    "bluetooth",
    "web-bluetooth",
    "uni-t",
    "ut60bt",
    "transport"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ble-multimeter/multimeter.git",
    "directory": "packages/web-bluetooth"
  },
  "homepage": "https://github.com/ble-multimeter/multimeter/tree/main/packages/web-bluetooth#readme",
  "bugs": {
    "url": "https://github.com/ble-multimeter/multimeter/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/mannes"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/mannes"
    }
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ble-multimeter/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/web-bluetooth": "^0.0.21",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
